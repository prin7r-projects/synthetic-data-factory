{
  "name": "@synthtable/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SynthTable API — Bun + Hono + Postgres + NATS",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.7.2",
    "nats": "^2.28.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.5",
    "typescript": "^5.7.3"
  }
}
